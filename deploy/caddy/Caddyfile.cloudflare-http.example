{
	email {$SANDBOX_ACME_EMAIL}
}

{$SANDBOX_DOMAIN} {
	encode zstd gzip
	reverse_proxy controller:8080
}

# Compatibility mode for a fixed, proxied, multi-level Cloudflare wildcard
# that does not have an Advanced edge certificate. Visitor traffic is HTTP.
http://*.{$SANDBOX_TUNNEL_DOMAIN} {
	reverse_proxy tunnel-edge:8080
}
